# Therapist Finder Configuration
# Copy this file to .env and adjust values as needed

# File paths
THERAPIST_FINDER_EMAIL_TEMPLATE_PATH=templates/email_template.txt
THERAPIST_FINDER_OUTPUT_DIRECTORY=clients

# Email settings
THERAPIST_FINDER_DEFAULT_SUBJECT=Terminanfrage

# Parser settings
THERAPIST_FINDER_MAX_ADDRESS_PARTS=2

# Output settings
THERAPIST_FINDER_JSON_INDENT=4

# Logging
THERAPIST_FINDER_LOG_LEVEL=INFO
